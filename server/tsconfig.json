{
	"compilerOptions": {
		"noEmit": true,
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",

		"skipLibCheck": true,
		"allowImportingTsExtensions": true,

		"baseUrl": "..",
		"paths": {
			"@shared/*": ["shared/*"]
		},

		"types": ["node"]
	},
	"include": ["./**/*.ts", "../shared/**/*.ts"],
	"exclude": ["../client", "../dist", "../node_modules"]
}